<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.retete.controller.MainController"
           fx:id="rootPane"
           style="-fx-background-color: #F5F5F0; -fx-background-radius: 20px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 30, 0, 0, 10);">

    <VBox>
        <!-- TITLE BAR -->
        <HBox fx:id="titleBar" styleClass="title-bar" prefHeight="44" alignment="CENTER_RIGHT" spacing="8"
              style="-fx-background-color: transparent; -fx-padding: 0 16 0 20;">
            <HBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                <Label text="🌿 RecipeBook" styleClass="sidebar-logo"
                       style="-fx-font-size: 16px; -fx-text-fill: #2D6A4F;"/>
            </HBox>
            <Button fx:id="btnMinimize" styleClass="btn-minimize" text=""/>
            <Button fx:id="btnClose" styleClass="btn-close" text=""/>
        </HBox>

        <!-- MAIN CONTENT -->
        <HBox VBox.vgrow="ALWAYS">

            <!-- SIDEBAR -->
            <VBox fx:id="sidebar" styleClass="sidebar" prefWidth="270" spacing="0">
                <padding><Insets top="20" right="16" bottom="20" left="16"/></padding>

                <Label text="🌿 RecipeBook" styleClass="sidebar-logo"/>
                <Label text="Planificator de Rețete Organice"
                       style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.6); -fx-padding: 2 0 20 0;"/>

                <TextField fx:id="campCautare" styleClass="sidebar-search"
                           promptText="&#128269;  Cauta retete..." maxWidth="Infinity">
                    <VBox.margin><Insets bottom="8"/></VBox.margin>
                </TextField>

                <ComboBox fx:id="comboCategorie" styleClass="sidebar-combo" maxWidth="Infinity"/>

                <Separator style="-fx-background-color: rgba(255,255,255,0.15);">
                    <VBox.margin><Insets top="12" bottom="4"/></VBox.margin>
                </Separator>

                <HBox alignment="CENTER_LEFT" style="-fx-padding: 8 0 4 0;">
                    <Label text="RETETE" style="-fx-font-size: 10px; -fx-font-weight: bold;
                                               -fx-text-fill: rgba(255,255,255,0.5);"/>
                    <Label fx:id="labelCount" style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.5);
                                                      -fx-padding: 0 0 0 8;"/>
                </HBox>

                <ListView fx:id="listaRetete" styleClass="recipe-list" VBox.vgrow="ALWAYS"/>
            </VBox>

            <!-- CONTENT AREA -->
            <StackPane fx:id="detailContainer" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS"
                       style="-fx-background-color: #F5F5F0;">

                <!-- RECIPE DETAIL (behind empty state) -->
                <ScrollPane fx:id="detailScrollPane" fitToWidth="true"
                            style="-fx-background-color: transparent; -fx-background: #F5F5F0; -fx-border-width: 0;">
                    <VBox fx:id="retetaContent" spacing="16" style="-fx-padding: 25px;" visible="false">

                        <!-- Hero Image -->
                        <StackPane fx:id="imageContainer" prefHeight="220"
                                   style="-fx-background-color: #E8E4DC; -fx-background-radius: 16px;">
                            <ImageView fx:id="heroImage" fitWidth="700" fitHeight="220"
                                       preserveRatio="false" smooth="true"/>
                            <Label fx:id="imagePlaceholder" text="&#127859;"
                                   style="-fx-font-size: 60px; -fx-opacity: 0.3;"/>
                        </StackPane>

                        <!-- Recipe Header -->
                        <VBox spacing="8" style="-fx-padding: 4 0 0 0;">
                            <Label fx:id="labelNume" styleClass="recipe-title" wrapText="true"/>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label fx:id="labelCategorie" styleClass="meta-label"/>
                                <Label fx:id="labelTimp" styleClass="meta-label"/>
                                <Label fx:id="labelPortii" styleClass="meta-label"/>
                            </HBox>
                            <Label fx:id="labelDescriere" wrapText="true"
                                   style="-fx-font-size: 14px; -fx-text-fill: #6B7280; -fx-padding: 4 0 0 0;"/>
                        </VBox>

                        <!-- Two columns: Ingredients + Instructions -->
                        <HBox spacing="16">

                            <!-- Ingredients Card -->
                            <VBox fx:id="ingredienteCard" styleClass="glass-card" HBox.hgrow="ALWAYS" spacing="12">
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="&#129388;" style="-fx-font-size: 18px;"/>
                                    <Label text="Ingrediente" styleClass="section-title"/>
                                </HBox>
                                <ScrollPane fitToWidth="true" prefHeight="220"
                                            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;">
                                    <FlowPane fx:id="panelIngrediente" hgap="12" vgap="12"
                                              style="-fx-padding: 4px;"/>
                                </ScrollPane>
                            </VBox>

                            <!-- Instructions Card -->
                            <VBox fx:id="instructiuniCard" styleClass="glass-card" prefWidth="280" spacing="12">
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="&#128203;" style="-fx-font-size: 18px;"/>
                                    <Label text="Instructiuni" styleClass="section-title"/>
                                </HBox>
                                <TextArea fx:id="areaInstructiuni" styleClass="instructions-area"
                                          editable="false" wrapText="true" prefHeight="220"
                                          style="-fx-background-color: transparent; -fx-border-width: 0;"/>
                            </VBox>
                        </HBox>

                        <!-- Add to Shopping List Button -->
                        <HBox alignment="CENTER_LEFT">
                            <Button fx:id="btnAdaugaInLista" text="&#10133;  Adauga la Lista de Cumparaturi"
                                    styleClass="btn-primary" onAction="#adaugaInListaCumparaturi"/>
                        </HBox>

                    </VBox>
                </ScrollPane>

                <!-- EMPTY STATE (on top, visible initially) -->
                <VBox fx:id="emptyState" alignment="CENTER" spacing="16" style="-fx-padding: 40;">
                    <Label text="&#127807;" styleClass="empty-icon"/>
                    <Label text="Bine ai venit in RecipeBook!" styleClass="empty-title"/>
                    <Label text="Selecteaza o reteta din stanga pentru a vedea detaliile"
                           styleClass="empty-subtitle" wrapText="true" textAlignment="CENTER"/>
                </VBox>

            </StackPane>

        </HBox>
    </VBox>

</StackPane>
