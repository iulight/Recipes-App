<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.retete.controller.MainController"
            stylesheets="@style.css">

    <!-- HEADER -->
    <top>
        <HBox styleClass="header" alignment="CENTER_LEFT" spacing="14">
            <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>
            <Label text="🍽️" style="-fx-font-size: 30px;"/>
            <VBox spacing="1">
                <Label text="RecipeBook" styleClass="header-title"/>
                <Label text="Rețete &amp; Cumpărături" styleClass="header-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="labelHeaderStats" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;"/>
        </HBox>
    </top>

    <center>
        <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" styleClass="tab-pane">

            <!-- ======= TAB RETETE ======= -->
            <Tab text="📖   Rețetele Mele">
                <SplitPane dividerPositions="0.30">

                    <!-- STANGA -->
                    <VBox styleClass="panel-left">
                        <!-- Search -->
                        <VBox spacing="8" styleClass="search-box">
                            <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                            <TextField fx:id="campCautare" promptText="🔍   Caută rețetă..." styleClass="search-field"/>
                            <ComboBox fx:id="comboCategorie" maxWidth="Infinity" styleClass="combo-field"/>
                        </VBox>

                        <!-- Count label -->
                        <HBox alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 6 14 6 14;">
                            <Label fx:id="labelCount" style="-fx-font-size: 11px; -fx-text-fill: #bbb;"/>
                        </HBox>

                        <!-- Lista -->
                        <ListView fx:id="listaRetete" VBox.vgrow="ALWAYS" styleClass="retete-list"/>

                        <!-- Butoane -->
                        <HBox spacing="8" styleClass="btn-bar">
                            <Button text="➕  Rețetă Nouă" onAction="#onAdaugaReteta"
                                    styleClass="btn-primary" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                            <Button text="🗑" onAction="#onStergeReteta" styleClass="btn-danger"
                                    style="-fx-min-width: 40px; -fx-pref-width: 40px;"/>
                        </HBox>
                    </VBox>

                    <!-- DREAPTA: Detalii -->
                    <ScrollPane fx:id="detailScroll" fitToWidth="true" styleClass="detail-scroll">
                        <VBox fx:id="detailPanel" styleClass="detail-panel" spacing="16">
                            <padding><Insets top="20" right="20" bottom="24" left="20"/></padding>

                            <!-- Placeholder când nu e selectat nimic -->
                            <VBox fx:id="emptyState" alignment="CENTER" spacing="12"
                                  style="-fx-padding: 80 0 0 0;">
                                <Label text="🍳" style="-fx-font-size: 60px;"/>
                                <Label text="Selectează o rețetă" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #ccc;"/>
                                <Label text="sau adaugă una nouă" style="-fx-font-size: 13px; -fx-text-fill: #ddd;"/>
                            </VBox>

                            <!-- Card principal reteta -->
                            <VBox fx:id="retetaContent" styleClass="reteta-card" spacing="0" visible="false" managed="false">
                                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

                                <!-- Titlu + badges -->
                                <VBox spacing="10">
                                    <Label fx:id="labelNume" styleClass="reteta-titlu" wrapText="true"/>
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Label fx:id="labelCategorie" styleClass="badge badge-red"/>
                                        <Label fx:id="labelTimp" styleClass="badge badge-gray"/>
                                        <Label fx:id="labelPortii" styleClass="badge badge-green"/>
                                    </HBox>
                                    <Label fx:id="labelDescriere" styleClass="descriere-label" wrapText="true"/>
                                </VBox>

                                <!-- Separator -->
                                <Region style="-fx-background-color: #f0ebe6; -fx-pref-height: 1; -fx-max-height: 1; -fx-margin: 16 0 16 0;"/>
                                <VBox.margin><Insets top="16" bottom="16"/></VBox.margin>
                            </VBox>

                            <!-- Card ingrediente -->
                            <VBox fx:id="ingredienteCard" styleClass="reteta-card" spacing="12" visible="false" managed="false">
                                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="🛒" style="-fx-font-size: 18px;"/>
                                    <Label text="Ingrediente" styleClass="section-title"/>
                                </HBox>
                                <FlowPane fx:id="panelIngrediente" hgap="8" vgap="8"
                                          styleClass="ingrediente-box">
                                    <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                                </FlowPane>
                            </VBox>

                            <!-- Card instructiuni -->
                            <VBox fx:id="instructiuniCard" styleClass="reteta-card" spacing="12" visible="false" managed="false">
                                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="👨‍🍳" style="-fx-font-size: 18px;"/>
                                    <Label text="Mod de preparare" styleClass="section-title"/>
                                </HBox>
                                <TextArea fx:id="areaInstructiuni" editable="false"
                                          styleClass="instructiuni-area"
                                          wrapText="true" prefHeight="170"/>
                            </VBox>

                            <!-- Buton adauga in lista -->
                            <Button fx:id="btnAdaugaInLista" visible="false" managed="false"
                                    text="🛒   Adaugă ingredientele în lista de cumpărături"
                                    onAction="#onAdaugaInLista"
                                    styleClass="btn-add-list"
                                    maxWidth="Infinity"/>

                        </VBox>
                    </ScrollPane>

                </SplitPane>
            </Tab>

            <!-- ======= TAB LISTA ======= -->
            <Tab text="🛒   Listă Cumpărături">
                <SplitPane dividerPositions="0.60">

                    <!-- STANGA: Lista -->
                    <VBox styleClass="panel-left">
                        <!-- Stats bar -->
                        <HBox styleClass="stats-bar" spacing="16" alignment="CENTER_LEFT">
                            <Label fx:id="labelTotal" styleClass="stat-label"/>
                            <Label text="·" styleClass="stat-label"/>
                            <Label fx:id="labelCumparate" styleClass="stat-label-accent"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="labelProgres" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        </HBox>

                        <!-- Progress bar -->
                        <HBox fx:id="progressBox" style="-fx-background-color: #c0392b; -fx-padding: 0 0 8 0;">
                            <Region fx:id="progressFill" style="-fx-background-color: rgba(255,255,255,0.5); -fx-pref-height: 4; -fx-background-radius: 0 2 2 0;" prefWidth="0"/>
                        </HBox>

                        <!-- Lista items -->
                        <ListView fx:id="listaItems" VBox.vgrow="ALWAYS" styleClass="cumparaturi-list"/>

                        <!-- Butoane -->
                        <VBox spacing="8" styleClass="btn-bar">
                            <HBox spacing="8">
                                <Button text="✅  Șterge bifate" onAction="#onStergeCumparate"
                                        styleClass="btn-secondary" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                                <Button text="🗑  Golește" onAction="#onGolesteLista"
                                        styleClass="btn-danger" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                            </HBox>
                            <Button text="🗑  Șterge selectat" onAction="#onStergeItem"
                                    styleClass="btn-secondary" maxWidth="Infinity"/>
                        </VBox>
                    </VBox>

                    <!-- DREAPTA: Adauga manual -->
                    <ScrollPane fitToWidth="true" style="-fx-background-color: #f8f4f0; -fx-border-color: transparent;">
                        <VBox styleClass="add-manual-panel" spacing="16">
                            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                            <!-- Card adauga -->
                            <VBox styleClass="add-card" spacing="14">
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="✏️" style="-fx-font-size: 18px;"/>
                                    <Label text="Adaugă produs" styleClass="section-title"/>
                                </HBox>
                                <Region style="-fx-background-color: #f0ebe6; -fx-pref-height: 1;"/>

                                <VBox spacing="6">
                                    <Label text="NUME PRODUS *" styleClass="field-label"/>
                                    <TextField fx:id="campNumeItem" promptText="ex: Ouă, Lapte, Pâine..." styleClass="input-field"/>
                                </VBox>
                                <HBox spacing="12">
                                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                                        <Label text="CANTITATE" styleClass="field-label"/>
                                        <TextField fx:id="campCantitateItem" promptText="ex: 2" styleClass="input-field"/>
                                    </VBox>
                                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                                        <Label text="UNITATE" styleClass="field-label"/>
                                        <TextField fx:id="campUnitateItem" promptText="buc, kg, l..." styleClass="input-field"/>
                                    </VBox>
                                </HBox>
                                <Button text="➕   Adaugă în listă" onAction="#onAdaugaItemManual"
                                        styleClass="btn-primary" maxWidth="Infinity"/>
                            </VBox>

                            <!-- Card tip -->
                            <VBox styleClass="tip-card" spacing="8">
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <Label text="💡" style="-fx-font-size: 16px;"/>
                                    <Label text="Sfat rapid" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #c0392b;"/>
                                </HBox>
                                <Label styleClass="tip-label" wrapText="true"
                                       text="Selectează o rețetă din tab-ul 'Rețetele Mele' și apasă butonul roșu pentru a adăuga automat toate ingredientele."/>
                            </VBox>

                        </VBox>
                    </ScrollPane>

                </SplitPane>
            </Tab>

        </TabPane>
    </center>
</BorderPane>
